rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // User profiles — only the owning user can read/write
    match /users/{uid} {
      allow read, write: if request.auth != null && request.auth.uid == uid;

      // Level progress subcollection
      match /progress/{levelId} {
        allow read, write: if request.auth != null && request.auth.uid == uid;
      }
    }

    // Leaderboards — anyone authenticated can read, only owner can write their entry
    match /leaderboards/{levelId}/entries/{entryUid} {
      allow read: if request.auth != null;
      allow write: if request.auth != null
                   && request.auth.uid == entryUid
                   && request.resource.data.moves is int
                   && request.resource.data.moves > 0;
    }
  }
}
