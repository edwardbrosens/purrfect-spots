rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // User profiles — owner can read/write own doc.
    // Public-readable so leaderboards / friend lookups can show display names.
    match /users/{uid} {
      allow read: if request.auth != null;
      allow create, update: if request.auth != null && request.auth.uid == uid;
      allow delete: if request.auth != null && request.auth.uid == uid;

      // Level progress subcollection — owner only
      match /progress/{levelId} {
        allow read, write: if request.auth != null && request.auth.uid == uid;
      }
    }

    // Username#tag reservations — anyone authenticated may claim a free slot
    // (transactional create-if-absent), but nobody can overwrite or delete one.
    match /usernames/{handle} {
      allow read: if request.auth != null;
      allow create: if request.auth != null;
      allow update, delete: if false;
    }

    // Leaderboards — anyone authenticated can read, only owner can write their entry
    match /leaderboards/{levelId}/entries/{entryUid} {
      allow read: if request.auth != null;
      allow write: if request.auth != null
                   && request.auth.uid == entryUid
                   && request.resource.data.moves is int
                   && request.resource.data.moves > 0;
    }
  }
}
